{
  "name": "tree-sitter-dreammaker",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for DreamMaker (DM) - the BYOND scripting language",
  "main": "bindings/node",
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/tree-sitter-dreammaker"
  },
  "keywords": [
    "parser",
    "lexer",
    "dreammaker",
    "dm",
    "byond"
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "tree-sitter": [
    {
      "scope": "source.dm",
      "file-types": [
        "dm",
        "dme"
      ],
      "highlights": ["queries/highlights.scm"],
      "injections": "queries/injections.scm",
      "indents": "queries/indents.scm"
    }
  ]
}
