    },
    "type_path": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "/"
              },
              {
                "type": "STRING",
                "value": "."
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_*][a-zA-Z0-9_*]*(?:\\/[a-zA-Z_*][a-zA-Z0-9_*]*)*"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "PATTERN",
                    "value": "\\/(?:proc|verb|var)"
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "PATTERN",
                        "value": "\\/(?:[a-zA-Z_][a-zA-Z0-9_]*)"
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
